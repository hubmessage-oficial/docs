                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendTextRequest": {
        "type": "object",
        "required": ["phone", "message"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "message": {
            "type": "string",
            "description": "Texto da mensagem",
            "example": "Bem-vindo ao *Hub Message*!"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          },
          "delayTyping": {
            "type": "integer",
            "description": "Tempo em segundos exibindo status \"digitando\" (1-15)",
            "minimum": 1,
            "maximum": 15
          },
          "editMessageId": {
            "type": "string",
            "description": "ID de uma mensagem enviada anteriormente para editar"
          }
        }
      },
      "SendImageRequest": {
        "type": "object",
        "required": ["phone", "image"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "image": {
            "type": "string",
            "description": "URL da imagem ou dados em Base64"
          },
          "caption": {
            "type": "string",
            "description": "Legenda da imagem"
          },
          "messageId": {
            "type": "string",
            "description": "ID de uma mensagem existente para responder"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          },
          "viewOnce": {
            "type": "boolean",
            "description": "Enviar como mensagem de visualização única",
            "default": false
          }
        }
      },
      "SendAudioRequest": {
        "type": "object",
        "required": ["phone", "audio"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "audio": {
            "type": "string",
            "description": "URL do áudio ou dados em Base64"
          },
          "viewOnce": {
            "type": "boolean",
            "description": "Enviar como mensagem de visualização única",
            "default": false
          },
"delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          },
          "delayTyping": {
            "type": "integer",
            "description": "Tempo em segundos exibindo status \"Gravando áudio...\" (1-15)",
            "minimum": 1,
            "maximum": 15
          }
        }
      },
      "SendRemoveReactionRequest": {
        "type": "object",
        "required": ["phone", "messageId"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "messageId": {
            "type": "string",
            "description": "ID da mensagem que terá a reação removida"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          }
        }
      },
      "SendReactionRequest": {
        "type": "object",
        "required": ["phone", "reaction", "messageId"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "reaction": {
            "type": "string",
            "description": "Emoji da reação",
            "example": "❤️"
          },
          "messageId": {
            "type": "string",
            "description": "ID da mensagem que receberá a reação"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          }
        }
      },
      "SendVideoRequest": {
        "type": "object",
        "required": ["phone", "video"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "video": {
            "type": "string",
            "description": "URL do vídeo ou dados em Base64"
          },
          "caption": {
            "type": "string",
            "description": "Legenda do vídeo"
          },
          "messageId": {
            "type": "string",
            "description": "ID de uma mensagem existente para responder"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          },
          "viewOnce": {
            "type": "boolean",
            "description": "Enviar como mensagem de visualização única",
            "default": false
          }
        }
      },
      "SendStickerRequest": {
        "type": "object",
        "required": ["phone", "sticker"],
        "properties": {
          "phone": {
            "type": "string",
            "description": "Telefone do destinatário (DDI + DDD + número)",
            "example": "5511999999999"
          },
          "sticker": {
            "type": "string",
            "description": "URL do sticker ou dados em Base64"
          },
          "stickerAuthor": {
            "type": "string",
            "description": "Nome do autor do sticker"
          },
          "messageId": {
            "type": "string",
            "description": "ID de uma mensagem existente para responder"
          },
          "delayMessage": {
            "type": "integer",
            "description": "Delay em segundos antes do envio (1-15)",
            "minimum": 1,
            "maximum": 15
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "zaapId": {
            "type": "string",
            "description": "Identificador interno"
          },
          "messageId": {
            "type": "string",
            "description": "ID da mensagem no WhatsApp"
          },
          "id": {
            "type": "string",
            "description": "Mesmo valor do messageId (compatibilidade)"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "integer",
            "description": "Código do erro"
          },
          "message": {
            "type": "string",
            "description": "Descrição do erro"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Secret Key gerada no painel de Segurança do Hub Message"
      }
    }
  }
}
