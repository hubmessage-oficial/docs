{
  "openapi": "3.1.0",
  "info": {
    "title": "Hub Message - Z-API Compatibilidade",
    "description": "API compatível com Z-API para facilitar a migração para o Hub Message",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://zapi.hubmessage.io/channels/{channel_id}/token/{channel_token}",
      "variables": {
        "channel_id": {
          "description": "ID do canal (equivalente ao instance_id da Z-API)",
          "default": "SEU_CANAL"
        },
        "channel_token": {
          "description": "Token do canal (equivalente ao token da Z-API)",
          "default": "SEU_TOKEN"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/send-text": {
      "post": {
        "summary": "Enviar texto",
        "description": "Envia uma mensagem de texto simples. Suporta formatação do WhatsApp, emojis e quebras de linha (`\\n`, `\\r`, `\\r\\n` ou `%0a`).",
        "operationId": "sendText",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendTextRequest"
              },
              "example": {
                "phone": "5511999999999",
                "message": "Bem-vindo ao *Hub Message*!"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-image": {
      "post": {
        "summary": "Enviar imagem",
        "description": "Envia uma mensagem com imagem. Aceita URL ou Base64 (com prefixo `data:image/png;base64,`).",
        "operationId": "sendImage",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendImageRequest"
              },
              "examples": {
                "url": {
                  "summary": "Envio por URL",
                  "value": {
                    "phone": "5511999999999",
                    "image": "https://exemplo.com/imagem.png",
                    "caption": "Confira essa imagem!",
                    "viewOnce": false
                  }
                },
                "base64": {
                  "summary": "Envio por Base64",
                  "value": {
                    "phone": "5511999999999",
                    "image": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAyAAAAMg...",
                    "caption": "Confira essa imagem!",
                    "viewOnce": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-remove-reaction": {
      "post": {
        "summary": "Remover reação",
        "description": "Remove uma reação (emoji) de uma mensagem existente.",
        "operationId": "sendRemoveReaction",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendRemoveReactionRequest"
              },
              "example": {
                "phone": "5511999999999",
                "messageId": "D241XXXX732339502B68"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reação removida com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-video": {
      "post": {
        "summary": "Enviar vídeo",
        "description": "Envia uma mensagem com vídeo. Aceita URL ou Base64 (com prefixo `data:video/mp4;base64,`).",
        "operationId": "sendVideo",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendVideoRequest"
              },
              "examples": {
                "url": {
                  "summary": "Envio por URL",
                  "value": {
                    "phone": "5511999999999",
                    "video": "https://exemplo.com/video.mp4",
                    "caption": "Confira esse vídeo!",
                    "viewOnce": false
                  }
                },
                "base64": {
                  "summary": "Envio por Base64",
                  "value": {
                    "phone": "5511999999999",
                    "video": "data:video/mp4;base64,AAYXJ0eHJlZgIGZ0eXBtc0eH...",
                    "caption": "Confira esse vídeo!",
                    "viewOnce": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-sticker": {
      "post": {
        "summary": "Enviar sticker",
        "description": "Envia um sticker (figurinha). Aceita URL ou Base64 (com prefixo `data:image/png;base64,`).",
        "operationId": "sendSticker",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendStickerRequest"
              },
              "examples": {
                "url": {
                  "summary": "Envio por URL",
                  "value": {
                    "phone": "5511999999999",
                    "sticker": "https://exemplo.com/sticker.png",
                    "stickerAuthor": "Hub Message"
                  }
                },
                "base64": {
                  "summary": "Envio por Base64",
                  "value": {
                    "phone": "5511999999999",
                    "sticker": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAyAAAAMg...",
                    "stickerAuthor": "Hub Message"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-reaction": {
      "post": {
        "summary": "Enviar reação",
        "description": "Envia uma reação (emoji) a uma mensagem existente. Funciona tanto para mensagens enviadas quanto recebidas.",
        "operationId": "sendReaction",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendReactionRequest"
              },
              "example": {
                "phone": "5511999999999",
                "reaction": "❤️",
                "messageId": "D241XXXX732339502B68"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reação enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
              }
            }
          },
          "405": {
            "description": "Método não permitido. Verifique se está usando POST.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 405,
                  "message": "Method not allowed"
                }
              }
            }
          },
          "415": {
            "description": "Content-Type inválido. Envie `Content-Type: application/json`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": 415,
                  "message": "Unsupported media type"
                }
              }
            }
          }
        }
      }
    },
    "/send-audio": {
      "post": {
        "summary": "Enviar áudio",
        "description": "Envia uma mensagem de áudio (mensagem de voz). Aceita URL ou Base64 (com prefixo `data:audio/mpeg;base64,`).",
        "operationId": "sendAudio",
        "tags": ["Mensagens"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendAudioRequest"
              },
              "examples": {
                "url": {
                  "summary": "Envio por URL",
                  "value": {
                    "phone": "5511999999999",
                    "audio": "https://exemplo.com/audio.mp3",
                    "viewOnce": false
                  }
                },
                "base64": {
                  "summary": "Envio por Base64",
                  "value": {
                    "phone": "5511999999999",
                    "audio": "data:audio/mpeg;base64,SUQzAwAAA...",
                    "viewOnce": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                },
                "example": {
                  "zaapId": "3999984263738042930CD6ECDE9VDWSA",
                  "messageId": "D241XXXX732339502B68",
                  "id": "D241XXXX732339502B68"
                }
